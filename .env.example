# ----- bff service environment ---------------------------------------
# Required
SERVICE_NAME=bff
DATABASE_URL=postgresql+psycopg://postgres:dev_pw@bff_db:5432/bff_db
PUBSUB_PROJECT_ID=local-eligibility
PUBSUB_EMULATOR_HOST=pubsub:8085

# Optional / observability
LOG_LEVEL=INFO
OTEL_EXPORTER_OTLP_ENDPOINT=http://jaeger:4317
TENANT_DEFAULT=11111111-1111-1111-1111-111111111111

# Standalone (no docker-compose) overrides
# DATABASE_URL=postgresql+psycopg://postgres:dev_pw@localhost:5441/postgres

# Downstream service URLs
ATLAS_URL=http://atlas:8000
MEMBER_URL=http://member:8000
GROUP_URL=http://group:8000
PLAN_URL=http://plan:8000

# Read model + search
ATLAS_DB_URL=postgresql+psycopg://postgres:dev_pw@atlas_db:5432/atlas_db
OPENSEARCH_URL=http://opensearch:9200

# Object storage (for file uploads)
MINIO_ENDPOINT=http://minio:9000
MINIO_BUCKET=eligibility-files
MINIO_ROOT_USER=minio
MINIO_ROOT_PASSWORD=minio12345

# ---- Production hardening (all optional, sensible defaults) ----
# DB_STATEMENT_TIMEOUT_MS=30000          # fail slow queries before they clog the pool
# DB_LOCK_TIMEOUT_MS=5000
# DB_IDLE_IN_TX_TIMEOUT_MS=60000
# DB_POOL_SIZE=10
# DB_MAX_OVERFLOW=20
# DB_POOL_TIMEOUT=10
# SHUTDOWN_GRACE_SECONDS=20              # drain window on SIGTERM (Cloud Run termination)

# ---- GCP-native observability (switch-on in production) ----
# Setting GOOGLE_CLOUD_PROJECT flips logging → Cloud Logging and tracing → Cloud Trace.
# Requires: poetry install --extras gcp
# GOOGLE_CLOUD_PROJECT=your-gcp-project
